@model IEnumerable<LOGIN.Models.Pedido>
<div class="container mt-4 text-light">
    <h2 class="text-warning">Historial de Ventas</h2>
    <div class="row mb-4">
        <div class="col-md-4"><div class="card card-lazaroni p-3"><h5>Total</h5><h3 class="text-success">Bs. @ViewBag.TotalVentas.ToString("0.00")</h3></div></div>
    </div>
    <table class="table table-dark table-hover">
        <thead><tr><th>ID</th><th>Cliente</th><th>Total</th><th>Estado</th></tr></thead>
        <tbody>
            @foreach(var p in Model) {
                <tr><td>#@p.Id</td><td>@p.Usuario?.Nombre</td><td>Bs. @p.Total.ToString("0.00")</td>
                <td>@(p.Estado == 1 ? "Completado" : "Pendiente")</td></tr>
            }
        </tbody>
    </table>
</div>