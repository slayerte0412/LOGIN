<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Fideos Lazaroni</title>

    <link rel="manifest" href="~/manifest.json" />
    <meta name="theme-color" content="#1a1a1a" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        * {
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: #f8f9fa;
            color: #333;
            min-height: 100vh;
            padding-bottom: 2rem;
        }

        .navbar-lazaroni {
            background-color: #1a1a1a !important;
            border-bottom: 4px solid #F39C12;
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }

        .card-custom {
            border: none;
            border-radius: 1rem;
            box-shadow: 0 8px 20px rgba(0,0,0,0.08);
            transition: all 0.3s ease;
            overflow: hidden;
            background: white;
        }

        .card-custom:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(243, 156, 18, 0.2);
            border: 1px solid rgba(243, 156, 18, 0.5);
        }

        .btn-custom-primary {
            background: linear-gradient(135deg, #FFD700 0%, #F39C12 100%);
            color: #1a1a1a !important;
            font-weight: 600;
            border: none;
            border-radius: 2rem;
            padding: 0.5rem 1.5rem;
            transition: all 0.3s;
        }

        .btn-custom-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(243, 156, 18, 0.4);
            background: linear-gradient(135deg, #F39C12 0%, #E67E22 100%);
            color: white !important;
        }

        .table-modern {
            border-radius: 1rem;
            overflow: hidden;
            background: white;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        .badge-stock {
            background-color: #1a1a1a;
            color: #FFD700;
            padding: 0.5rem 1rem;
            border-radius: 2rem;
            font-weight: 500;
        }

        footer {
            background-color: #1a1a1a;
            color: rgba(255,255,255,0.7);
            text-align: center;
            margin-top: 3rem;
            padding: 1.5rem 0;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-lazaroni">
            <div class="container">
                <a class="navbar-brand fw-bold text-warning" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-box-seam me-2"></i>LAZARONI
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Tienda" asp-action="Index">
                                <i class="bi bi-shop me-1"></i>Catálogo
                            </a>
                        </li>

                        @if (!string.IsNullOrEmpty(Context.Session.GetString("UsuarioId")))
                        {
                            @if (Context.Session.GetString("UsuarioRol") == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-warning" asp-controller="ProductosView" asp-action="Index">
                                        <i class="bi bi-grid-3x3-gap-fill me-1"></i>Inventario Adm
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-warning" asp-controller="Home" asp-action="Index">
                                        <i class="bi bi-bar-chart-fill me-1"></i>Dashboard
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Tienda" asp-action="Carrito">
                                        <i class="bi bi-cart me-1"></i>Mi Carrito
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Tienda" asp-action="MisCompras">
                                        <i class="bi bi-clock-history me-1"></i>Mis Compras
                                    </a>
                                </li>
                            }
                            
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-1"></i>Cerrar Sesión
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Iniciar Sesión</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register">Registrarse</a></li>
                        }
                    </ul>
                    
                    @if (!string.IsNullOrEmpty(Context.Session.GetString("UsuarioId")))
                    {
                        <span class="navbar-text text-white">
                            <i class="bi bi-person-circle me-1"></i>@Context.Session.GetString("UsuarioNombre")
                            <span class="badge bg-warning text-dark ms-2">@Context.Session.GetString("UsuarioRol")</span>
                        </span>
                    }
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>
    
    <footer>
        <div class="container">
            <small>© @DateTime.Now.Year - Fideos Lazaroni. Todos los derechos reservados.</small>
        </div>
    </footer>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .then(reg => console.log('PWA: Service Worker registrado con éxito.', reg.scope))
                    .catch(err => console.log('PWA: Error al registrar el Service Worker.', err));
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>