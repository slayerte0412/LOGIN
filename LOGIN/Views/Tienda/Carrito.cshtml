@model List<LOGIN.Models.CarritoItem>
@{ ViewData["Title"] = "Mi Carrito"; }
<div class="card card-custom bg-white p-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-cart3 text-primary"></i> Mi Carrito</h2>
    @if (!Model.Any()) {
        <div class="text-center py-5">
            <i class="bi bi-cart-x fs-1 text-muted"></i>
            <h4 class="mt-3">Tu carrito está vacío</h4>
            <a asp-action="Index" class="btn btn-custom-primary mt-3">Seguir comprando</a>
        </div>
    } else {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr class="table-light"><th>Producto</th><th class="text-center">Cantidad</th><th class="text-end">Precio</th><th class="text-end">Subtotal</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td><h6 class="mb-0 fw-bold">@item.Producto?.Nombre</h6></td>
                            <td class="text-center">
                                <div class="input-group input-group-sm justify-content-center" style="width: 130px; margin:0 auto;">
                                    <button class="btn btn-outline-secondary btn-minus" data-id="@item.Id">-</button>
                                    <input type="text" class="form-control text-center cantidad-input" value="@item.Cantidad" readonly />
                                    <button class="btn btn-outline-secondary btn-plus" data-id="@item.Id">+</button>
                                </div>
                            </td>
                            <td class="text-end">@item.Producto?.Precio.ToString("C")</td>
                            <td class="text-end fw-bold">@((item.Cantidad * (item.Producto?.Precio ?? 0)).ToString("C"))</td>
                            <td class="text-center"><button class="btn btn-sm btn-outline-danger btn-remove" data-id="@item.Id"><i class="bi bi-trash"></i></button></td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr><td colspan="3" class="text-end fw-bold fs-5">Total:</td><td class="text-end fw-bold fs-4 text-primary">@ViewBag.Total.ToString("C")</td><td></td></tr>
                </tfoot>
            </table>
        </div>
        <div class="d-flex justify-content-between mt-4">
            <a asp-action="Index" class="btn btn-light rounded-pill">Seguir comprando</a>
            <a asp-action="Checkout" class="btn btn-custom-primary">Proceder al pago</a>
        </div>
    }
</div>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $('.btn-plus').click(function() {
        var id = $(this).data('id');
        var val = parseInt($(this).siblings('input').val()) + 1;
        $.post('/Tienda/ActualizarCantidad', { itemId: id, cantidad: val }).done(function() { location.reload(); });
    });
    $('.btn-minus').click(function() {
        var id = $(this).data('id');
        var val = parseInt($(this).siblings('input').val()) - 1;
        $.post('/Tienda/ActualizarCantidad', { itemId: id, cantidad: val }).done(function() { location.reload(); });
    });
    $('.btn-remove').click(function() {
        if(confirm('¿Eliminar del carrito?')) {
            $.post('/Tienda/ActualizarCantidad', { itemId: $(this).data('id'), cantidad: 0 }).done(function() { location.reload(); });
        }
    });
</script>