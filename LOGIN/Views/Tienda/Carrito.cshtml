@model IEnumerable<LOGIN.Models.CarritoItem>
@{ ViewData["Title"] = "Mi Carrito"; }

<div class="container mt-4 bg-white p-4 rounded-4 shadow-sm text-light">
    <h2 class="mb-4 text-warning"><i class="bi bi-cart4"></i> Tu Carrito de Compras</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-dark text-center border-warning">
            <h4>Tu carrito está vacío</h4>
            <p>¡Agrega algunos deliciosos fideos para empezar!</p>
            <a asp-action="Index" class="btn btn-lazaroni mt-2">Volver a la tienda</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle">
                <thead>
                    <tr class="text-warning">
                        <th>Producto</th>
                        <th>Precio Unitario</th>
                        <th>Cantidad</th>
                        <th>Subtotal</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr id="fila-@item.ProductoId">
                            <td>@item.Producto.Nombre</td>
                            <td>Bs. @item.Producto.Precio.ToString("0.00")</td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <button type="button" class="btn btn-outline-warning btn-restar" data-id="@item.ProductoId">-</button>
                                    <span class="btn btn-dark disabled cantidad-texto" id="cant-@item.ProductoId">@item.Cantidad</span>
                                    <button type="button" class="btn btn-outline-warning btn-sumar" data-id="@item.ProductoId">+</button>
                                </div>
                            </td>
                            <td class="fw-bold text-success subtotal-texto" id="subtotal-@item.ProductoId">
                                Bs. @((item.Producto.Precio * item.Cantidad).ToString("0.00"))
                            </td>
                            <td>
                                <button class="btn btn-sm btn-danger btn-eliminar" data-id="@item.ProductoId">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4 p-3 bg-dark rounded border border-secondary">
            <h4 class="mb-0">Total estimado: <span class="text-success fw-bold" id="granTotal">Bs. @Model.Sum(i => i.Producto.Precio * i.Cantidad).ToString("0.00")</span></h4>
            
            <a asp-action="Checkout" class="btn btn-lg btn-lazaroni">
                Proceder al Pago <i class="bi bi-credit-card ms-2"></i>
            </a>
        </div>
    }
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            
            function actualizarCantidad(productoId, operacion) {
                $.post('/Tienda/ActualizarCantidadCarrito', { productoId: productoId, operacion: operacion })
                .done(function (res) {
                    if (res.success) {
                        $('#cant-' + productoId).text(res.cantidad);
                        $('#subtotal-' + productoId).text(res.subtotalFormateado);
                        recalcularTotal();
                    } else {
                        alert("No se pudo actualizar la cantidad. Revisa el stock disponible.");
                    }
                });
            }

            $('.btn-sumar').click(function () {
                var pid = $(this).data('id');
                actualizarCantidad(pid, 'sumar');
            });

            $('.btn-restar').click(function () {
                var pid = $(this).data('id');
                actualizarCantidad(pid, 'restar');
            });

            function recalcularTotal() {
                var total = 0;
                $('.subtotal-texto').each(function () {
                    var valor = parseFloat($(this).text().replace('Bs.', '').trim());
                    if(!isNaN(valor)) total += valor;
                });
                $('#granTotal').text('Bs. ' + total.toFixed(2));
            }
        });
    </script>
}