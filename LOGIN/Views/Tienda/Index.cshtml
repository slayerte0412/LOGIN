@model IEnumerable<LOGIN.Models.Producto>
@{ ViewData["Title"] = "Tienda"; }
<div class="container mt-4 bg-white p-4 rounded-4 shadow-sm">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 fw-bold text-dark"><i class="bi bi-shop"></i> Nuestros Productos</h1>
            <p class="text-muted">Lo mejor para tu hogar</p>
        </div>
        <a asp-action="Carrito" class="btn btn-custom-primary position-relative">
            <i class="bi bi-cart3 fs-5"></i>
            @if (ViewBag.CarritoCount > 0) {
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">@ViewBag.CarritoCount</span>
            }
            <span class="ms-2">Carrito</span>
        </a>
    </div>
    <div class="row g-4">
        @foreach (var producto in Model) {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card card-custom h-100 border">
                    <div class="card-img-top text-center pt-4 bg-light">
                        <i class="bi bi-box-seam" style="font-size: 4rem; color: #667eea;"></i>
                    </div>
                    <div class="card-body d-flex flex-column justify-content-between">
                        <div>
                            <h5 class="card-title fw-bold text-dark">@producto.Nombre</h5>
                            <p class="text-muted small">@(producto.Descripcion?.Length > 60 ? producto.Descripcion.Substring(0, 60) + "..." : producto.Descripcion ?? "Sin descripción")</p>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="fs-4 fw-bold text-primary">@producto.Precio.ToString("C")</span>
                            @if (producto.Cantidad > 0) {
                                <button class="btn btn-sm btn-custom-primary add-to-cart" data-id="@producto.Id">Agregar</button>
                            } else {
                                <button class="btn btn-sm btn-secondary" disabled>Agotado</button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $('.add-to-cart').click(function() {
        var productoId = $(this).data('id');
        $.post('/Tienda/AgregarAlCarrito', { productoId: productoId, cantidad: 1 })
        .done(function(res) {
            if (res.success) { alert(res.message); location.reload(); }
            else { alert(res.message); }
        });
    });
</script>