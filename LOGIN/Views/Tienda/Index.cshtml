@model IEnumerable<LOGIN.Models.Producto>

@{
    ViewData["Title"] = "Tienda";
}

<div class="container mt-4 bg-white p-4 rounded-4 shadow-sm">
    
    <div class="row mb-4 align-items-center">
        <div class="col-md-5">
            <h1 class="display-6 fw-bold text-dark"><i class="bi bi-shop text-warning me-2"></i>Nuestros Productos</h1>
            <p class="text-muted">Descubre la calidad de Fideos Lazaroni</p>
        </div>
        <div class="col-md-4 mb-3 mb-md-0">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="buscadorProductos" class="form-control border-start-0" placeholder="Ej: Fideo Corbata, Espagueti...">
            </div>
        </div>
        <div class="col-md-3 text-md-end">
            <a asp-action="Carrito" class="btn btn-dark-lazaroni position-relative">
                <i class="bi bi-cart3 fs-5"></i>
                @if (ViewBag.CarritoCount > 0)
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">@ViewBag.CarritoCount</span>
                }
                <span class="ms-2">Carrito</span>
            </a>
        </div>
    </div>

    <div class="row g-4" id="contenedorProductos">
        @foreach (var producto in Model.Where(p => p.Activo))
        {
            <div class="col-md-6 col-lg-4 col-xl-3 producto-tarjeta">
                <div class="card card-lazaroni h-100 border">
                    
                    @if (!string.IsNullOrEmpty(producto.ImagenBase64))
                    {
                        <img src="@producto.ImagenBase64" class="card-img-top" alt="@producto.Nombre" style="height: 200px; object-fit: cover;">
                    }
                    else if (!string.IsNullOrEmpty(producto.ImagenLocal))
                    {
                        <img src="~/images/imagesproductos/@producto.ImagenLocal" class="card-img-top" alt="@producto.Nombre" style="height: 200px; object-fit: cover;" onerror="this.src='/images/icon-512x512.png'">
                    }
                    else
                    {
                        <div class="card-img-top text-center bg-light" style="height: 200px; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-box-seam" style="font-size: 4rem; color: #ccc;"></i>
                        </div>
                    }

                    <div class="card-body d-flex flex-column justify-content-between">
                        <div>
                            <h5 class="card-title fw-bold text-dark nombre-producto">@producto.Nombre</h5>
                            <p class="text-muted small">@(producto.Descripcion?.Length > 60 ? producto.Descripcion.Substring(0, 60) + "..." : producto.Descripcion ?? "Sin descripción")</p>
                        </div>
                        
                        <div class="mt-3">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="fs-5 fw-bold text-success">Bs. @producto.Precio.ToString("0.00")</span>
                                <span class="badge badge-lazaroni">Stock: @producto.Cantidad</span>
                            </div>

                            @if (string.IsNullOrEmpty(Context.Session.GetString("UsuarioId")))
                            {
                                <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-dark-lazaroni w-100">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Iniciar sesión
                                </a>
                            }
                            else if (producto.Cantidad > 0)
                            {
                                <button class="btn btn-sm btn-lazaroni w-100 add-to-cart" data-id="@producto.Id">
                                    <i class="bi bi-cart-plus me-1"></i> Agregar al Carrito
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-secondary w-100" disabled>Agotado</button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $('.add-to-cart').click(function() {
            var productoId = $(this).data('id');
            $.post('/Tienda/AgregarAlCarrito', { productoId: productoId, cantidad: 1 })
            .done(function(res) {
                if (res.success) {
                    alert(res.message);
                    location.reload();
                } else {
                    alert(res.message);
                }
            });
        });

        document.getElementById('buscadorProductos').addEventListener('keyup', function () {
            let filtro = this.value.toLowerCase();
            let tarjetas = document.querySelectorAll('.producto-tarjeta');

            tarjetas.forEach(function (tarjeta) {
                let nombreProducto = tarjeta.querySelector('.nombre-producto').innerText.toLowerCase();
                if (nombreProducto.includes(filtro)) {
                    tarjeta.style.display = '';
                } else {
                    tarjeta.style.display = 'none';
                }
            });
        });
    </script>
}
