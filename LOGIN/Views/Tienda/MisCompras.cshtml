@model List<LOGIN.Models.Pedido>
@{ ViewData["Title"] = "Mis Compras"; }
<div class="card card-custom bg-white p-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-clock-history text-info"></i> Mis Compras</h2>
    @if (!Model.Any()) {
        <div class="text-center py-5">
            <i class="bi bi-receipt fs-1 text-muted"></i>
            <h4 class="mt-3">No has realizado compras aún</h4>
            <a asp-action="Index" class="btn btn-custom-primary mt-3">Comenzar a comprar</a>
        </div>
    } else {
        @foreach (var pedido in Model) {
            <div class="card border mb-4 shadow-sm">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <div>
                        <strong>Pedido #@pedido.Id</strong>
                        <span class="badge bg-success ms-2">@pedido.Estado</span>
                    </div>
                    <small class="text-muted">@pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")</small>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-8">
                            <table class="table table-sm text-dark">
                                <thead><tr><th>Producto</th><th>Cant.</th><th>Precio</th><th>Subtotal</th></tr></thead>
                                <tbody>
                                    @foreach (var det in pedido.Detalles!) {
                                        <tr><td>@det.Producto?.Nombre</td><td>@det.Cantidad</td><td>@det.PrecioUnitario.ToString("C")</td><td>@det.Subtotal.ToString("C")</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="col-md-4 bg-light p-3 rounded text-dark">
                            <p class="mb-1"><strong>Total Pagado:</strong> @pedido.Total.ToString("C")</p>
                            <p class="mb-1"><strong>Destino:</strong> @pedido.DireccionEnvio</p>
                            <p class="mb-0"><strong>Ref:</strong> @pedido.NumeroReferencia</p>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>