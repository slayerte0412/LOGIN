@{ ViewData["Title"] = "Inicio"; }
<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card card-custom p-5 text-center bg-white">
            <i class="bi bi-emoji-smile text-primary" style="font-size: 4rem;"></i>
            <h2 class="fw-bold mt-3">¡Bienvenido, @ViewBag.NombreUsuario!</h2>
            <p class="text-muted">Has iniciado sesión correctamente en el sistema web unificado.</p>
            <div class="d-flex gap-3 justify-content-center mt-4">
                <a asp-controller="Tienda" asp-action="Index" class="btn btn-custom-primary">Ir a la Tienda</a>
                <a asp-controller="ProductosView" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Administrar Stock</a>
            </div>
        </div>
    </div>
</div>