@model LOGIN.Models.Producto

@{
    ViewData["Title"] = "Crear Producto";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card card-lazaroni shadow-lg border-0 rounded-4" style="background-color: #1e1e1e;">
                <div class="card-header border-bottom border-secondary text-center py-4" style="background-color: #1a1a1a;">
                    <h2 class="fw-bold text-warning mb-0"><i class="bi bi-box-seam me-2"></i>Nuevo Producto</h2>
                    <p class="text-muted mb-0">Añade un nuevo fideo al catálogo de Lazaroni</p>
                </div>
                <div class="card-body p-4 text-light">
                    
                    <form asp-action="Create" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label asp-for="Nombre" class="form-label text-warning fw-bold">Nombre del Producto</label>
                                <input asp-for="Nombre" class="form-control bg-dark text-light border-secondary" placeholder="Ej. Fideo Corbata 400g" />
                                <span asp-validation-for="Nombre" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="Descripcion" class="form-label text-warning fw-bold">Descripción</label>
                                <textarea asp-for="Descripcion" class="form-control bg-dark text-light border-secondary" rows="3" placeholder="Detalles del producto..."></textarea>
                                <span asp-validation-for="Descripcion" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Precio" class="form-label text-warning fw-bold">Precio (Bs.)</label>
                                <input asp-for="Precio" type="number" step="0.01" class="form-control bg-dark text-light border-secondary" placeholder="0.00" />
                                <span asp-validation-for="Precio" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Cantidad" class="form-label text-warning fw-bold">Stock Inicial</label>
                                <input asp-for="Cantidad" type="number" class="form-control bg-dark text-light border-secondary" placeholder="0" />
                                <span asp-validation-for="Cantidad" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12 mt-4">
                                <label class="form-label text-warning fw-bold"><i class="bi bi-image me-2"></i>Subir Imagen del Producto (Opcional)</label>
                                <input type="file" name="imagenUpload" class="form-control bg-dark text-light border-secondary" accept="image/*" />
                                <small class="text-muted">Si no subes nada, se mostrará un ícono por defecto.</small>
                            </div>

                            <div class="col-md-12 mt-3">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" asp-for="Activo" checked>
                                    <label class="form-check-label text-light" asp-for="Activo">Producto Activo (Visible en la tienda)</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-5">
                            <a asp-action="Index" class="btn btn-outline-light px-4">
                                <i class="bi bi-arrow-left me-2"></i>Volver al Catálogo
                            </a>
                            <button type="submit" class="btn btn-lazaroni px-5">
                                <i class="bi bi-save me-2"></i>Guardar Producto
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
