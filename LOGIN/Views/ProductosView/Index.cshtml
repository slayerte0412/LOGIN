@model IEnumerable<LOGIN.Models.Producto>
@{ ViewData["Title"] = "Productos"; }
<div class="card card-custom bg-white p-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
        <div>
            <h2 class="h3 mb-1 fw-bold"><i class="bi bi-box-seam text-primary me-2"></i>Mi Inventario</h2>
            <p class="text-muted small mb-0"><i class="bi bi-database"></i> Total: @Model.Count() productos</p>
        </div>
        <a asp-action="Create" class="btn btn-gradient" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 2rem; padding: 0.5rem 1.25rem;"><i class="bi bi-plus-circle me-2"></i>Nuevo Producto</a>
    </div>
    @if (TempData["Mensaje"] != null) {
        <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!Model.Any()) {
        <div class="text-center py-5">
            <i class="bi bi-inbox fs-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No hay productos registrados</h4>
        </div>
    } else {
        <div class="table-responsive">
            <table class="table table-hover align-middle table-modern">
                <thead class="table-light">
                    <tr>
                        <th>ID</th><th>Nombre</th><th>Descripción</th><th class="text-center">Stock</th><th class="text-end">Precio</th><th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td class="text-secondary fw-bold">#@item.Id</td>
                            <td class="fw-semibold">@item.Nombre</td>
                            <td class="text-muted small">@(item.Descripcion?.Length > 60 ? item.Descripcion.Substring(0, 60) + "..." : item.Descripcion ?? "—")</td>
                            <td class="text-center">
                                @if (item.Cantidad == 0) { <span class="badge-stock" style="background: #fee2e2; color: #dc2626; padding: 0.5rem 1rem; border-radius: 2rem; font-weight: 500;">Sin stock</span> }
                                else if (item.Cantidad < 5) { <span class="badge-stock" style="background: #fed7aa; color: #ea580c; padding: 0.5rem 1rem; border-radius: 2rem; font-weight: 500;">@item.Cantidad uds</span> }
                                else { <span class="badge-stock" style="background: #dcfce7; color: #16a34a; padding: 0.5rem 1rem; border-radius: 2rem; font-weight: 500;">@item.Cantidad uds</span> }
                            </td>
                            <td class="text-end fw-bold fs-5 text-primary">@item.Precio.ToString("C")</td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning"><i class="bi bi-pencil"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>